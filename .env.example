# Discord Bot
BOT_TOKEN=seu_token_do_bot_aqui
DISCORD_CLIENT_ID=seu_client_id
DISCORD_CLIENT_SECRET=seu_client_secret

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_postgres
DB_NAME=oab_bot
DB_SSL=false

# Environment
NODE_ENV=production
DEBUG=false

# Configurações do Bot
PREFIX=!
LANGUAGE=pt-BR

# YouTube API (para música)
YOUTUBE_API_KEY=sua_chave_api_youtube

# Webhooks (opcional)
DISCORD_WEBHOOK_LOGS=url_do_webhook

# Timeout
INACTIVITY_TIMEOUT=300000
